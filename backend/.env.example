# ============================================
# Pocket NOC Backend — Environment Variables
# ============================================
#
# LOCAL (Docker Compose): copy this to .env and fill in values
# RAILWAY: set these in the Railway dashboard (Variables tab)
#   Railway auto-provides: DATABASE_URL, PORT, PGHOST, etc.

# Database
# Railway: auto-provided when you add the PostgreSQL plugin — skip this
# Docker: set to your local postgres connection
DATABASE_URL=postgresql://pocketnoc:CHANGE_ME@db:5432/pocketnoc
DB_PASSWORD=CHANGE_ME

# Auth — generate with: openssl rand -hex 32
# IMPORTANT: if you change this, all existing users get logged out
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# API
# Railway: PORT is auto-provided — skip API_PORT
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS — your public URL, comma-separated
# Railway: use your Railway domain, e.g. https://pocket-noc-api.up.railway.app
ALLOWED_ORIGINS=https://your-app.up.railway.app
